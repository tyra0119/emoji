# DB からデータ取得
stamp_ranking = []
text_ranking   = []

if os.path.exists(DB_PATH):
    conn = sqlite3.connect(DB_PATH)
    conn.row_factory = sqlite3.Row
    cur = conn.cursor()

    # 人気スタンプ（スタンプ単位）
    cur.execute('''
        SELECT stamp_id, COUNT(*) as cnt,
               MAX(datetime) as last_used
        FROM stamp_popular
        GROUP BY stamp_id
        ORDER BY cnt DESC, last_used DESC
    ''')
    stamp_ranking = cur.fetchall()

    # 人気スタンプ×文字列
    cur.execute('''
        SELECT stamp_id, selected_text, COUNT(*) as cnt,
               MAX(datetime) as last_used
        FROM stamp_popular
        GROUP BY stamp_id, selected_text
        ORDER BY cnt DESC, last_used DESC
    ''')
    text_ranking = cur.fetchall()
    conn.close()

